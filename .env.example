# Tant que ces deux variables ne sont pas renseignees, l'application utilise
# automatiquement la couche de service mock (localStorage) au lieu de Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Surcharge optionnelle de la date de l'evenement (format ISO, ex: 2026-07-25).
# Utile en developpement pour tester le mode "jour J" sans attendre la vraie date.
VITE_EVENT_DATE=2026-07-25
